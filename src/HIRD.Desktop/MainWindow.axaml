<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HIRD.Desktop.MainWindow"
        Title="HIRD Desktop"
        Width="500" Height="500">
    <TabControl>
        <TabItem Header="Controls">
            <StackPanel Margin="20">
                <TextBlock Text="HIRD Server" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="StatusLabel" Text="Status: Initializing..." FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="InfoLabel" Text="" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Button x:Name="StartStopButton" Content="Start Server" HorizontalAlignment="Stretch" Margin="0,10,0,0" Click="OnStartStopClick"/>

                <Expander Header="Connected Clients" Margin="0,20,0,0">
                    <ListBox x:Name="ConnectedClientsList" Height="100"/>
                </Expander>
            </StackPanel>
        </TabItem>
        <TabItem Header="Diagnostics">
            <StackPanel Margin="20">
                <TextBlock Text="Provider Diagnostics" FontSize="20" Margin="0,0,0,10"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Active Provider:" Margin="0,5,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ActiveProviderLabel" Text="Unknown" Margin="0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Capabilities:" Margin="0,5,10,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CapabilitiesLabel" Text="N/A" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Platform:" Margin="0,5,10,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PlatformLabel" Text="Unknown" Margin="0,5"/>
                </Grid>

                <TextBlock Text="System Info" FontSize="20" Margin="0,20,0,10"/>
                <TextBlock x:Name="SystemInfoLabel" Text="Waiting for server start..." TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
